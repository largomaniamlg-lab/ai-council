# Copia este archivo a .env.local y rellena las claves que vayas a usar.

# Council Simulator: motor gratuito que interpreta todos los roles con un
# unico modelo (via OpenRouter, sin tarjeta). Crea tu key en openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelo gratuito usado por el Council Simulator (opcional). Si el que viene
# por defecto deja de estar disponible, comprueba
# openrouter.ai/models?max_price=0 y pon aqui el id del modelo que quieras usar.
OPENROUTER_SIMULATOR_MODEL=

# Live Mode: proveedor real usado por cada rol en produccion (ver
# src/config/councilRoles.ts). Hoy todos los roles apuntan a OpenAI.
OPENAI_API_KEY=

# Proveedores preparados para el roadmap v1.5 (opcionales por ahora,
# permitiran asignar un proveedor real distinto a cada rol)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Supabase (opcional). Sin esto, la app funciona pero no guarda proyectos ni sesiones.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
